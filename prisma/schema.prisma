generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("student") // "student" or "admin"
  college   String?
  year      String?
  plan      String   @default("free") // "free", "premium", "annual"
  mobile    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
